<?xml version="1.0"?>
<gdml>
  <solids>
    <box name="WorldBox" x="1000" y="1000" z="1000"/>
    <box name="LArBox" x="100" y="100" z="100"/>
  </solids>

  <structure>
    <!-- Position for LAr -->
    <position name="LAr_pos" x="0" y="0" z="0"/>

    <!-- LAr volume -->
    <volume name="LAr">
      <materialref ref="G4_lAr"/>
      <solidref ref="LArBox"/>
    </volume>

    <!-- World volume -->
    <volume name="World">
      <materialref ref="G4_AIR"/>
      <solidref ref="WorldBox"/>

      <!-- Place LAr inside World -->
      <physvol>
        <volumeref ref="LAr"/>
        <positionref ref="LAr_pos"/>
      </physvol>
    </volume>
  </structure>

  <setup name="Default" version="1.0">
    <world ref="World"/>
  </setup>
</gdml>
