# ==============================
# --- Physics list settings ---
# ==============================



# Read your GDML detector description
/detector/readGDML /workspace/neutrino_demo/output.gdml

#/physics_lists/em/addNeutrino


# Set detector name first, BEFORE initializing physics list
/physics_lists/em/NuDetectorName MAIADetector

# Activate neutrino physics
/physics_lists/em/NeutrinoActivation true
#/physics_lists/em/NuETotXscActivation true
#/physics_lists/nu/NeETotXscActivation  true

# Set neutrino bias factors
/physics_lists/em/NuEleCcBias 5e14
/physics_lists/em/NuEleNcBias 5e14
#/physics_lists/em/NeETotXscActivation  true
/physics_lists/em/NuNucleusBias 1e14

# EM / other processes
#/physics_lists/em/SyncRadiation true
#/physics_lists/em/SyncRadiationAll true
#/physics_lists/em/GammaNuclear true
#/physics_lists/em/UseGammaNuclearXS false
#/physics_lists/em/LENDGammaNuclear false
#/physics_lists/em/ElectroNuclear true
#/physics_lists/em/MuonNuclear false
#/physics_lists/em/GammaToMuons false
#/physics_lists/em/PositronToMuons true
#/physics_lists/em/PositronToHadrons true

# Optional conversion factors (uncomment to use)
#/physics_lists/em/GammaToMuonsFactor 1.0
#/physics_lists/em/PositronToMuonsFactor 1.0
#/physics_lists/em/PositronToHadronsFactor 1.0

